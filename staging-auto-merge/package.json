{
  "name": "staging-auto-merge",
  "version": "1.0.0",
  "description": "GitHub Action to maintain a staging branch from labeled pull requests",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "bundle": "ncc build src/index.js -o dist",
    "build": "npm run bundle",
    "all": "npm test && npm run bundle"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^6.0.0"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.1",
    "jest": "^29.7.0"
  }
}
